{
  "name": "horizon-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "npm run dev --prefix server",
    "build": "tsc && vite build",
    "build:vercel": "npm run build && npm run build:server:vercel && npm run db:prepare:vercel",
    "build:server": "npm run build --prefix server",
    "build:server:vercel": "cd server && npx prisma generate && npm run build",
    "db:prepare:vercel": "cd server && npx prisma db push && node --experimental-strip-types prisma/seed.ts",
    "preview": "vite preview",
    "db:up": "docker compose up -d",
    "db:setup": "npm run db:setup --prefix server"
  },
  "dependencies": {
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.400.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.8",
    "recharts": "^2.12.7",
    "serverless-http": "^3.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vercel/node": "^5.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "playwright": "^1.60.0",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.4.5",
    "vite": "^5.3.4"
  }
}