{
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "dist",
  "installCommand": "npm install && npm install --prefix server",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "JWT_SECRET": "horizon-express-jwt-production-secret-2024"
  },
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "includeFiles": "server/{dist/**,prisma/dev.db,node_modules/.prisma/**,node_modules/@prisma/client/**}"
    }
  }
}
